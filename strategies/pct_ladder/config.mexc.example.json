{
  "strategy_name": "pct_ladder",
  "runner_type": "reactive",
  "broker": {
    "type": "mexc_spot",
    "base_url": "https://api.mexc.com",
    "recv_window_ms": 5000,
    "timeout_s": 10,
    "secrets_file": "secrets/mexc_spot.json"
  },
  "strategy": {
    "symbols": ["ETHUSDT"],
    "upper_pct": 1.0,
    "lower_pct": 1.0,
    "sizing_mode": "fixed_quote",
    "buy_quote": 300,
    "sell_quote": 290,
    "qty_step": 1e-06,
    "min_qty": 1e-06
  },
  "execution": {
    "poll_seconds": 2,
    "order_mode": "marketable_limit",
    "slippage_bps": 10,
    "limit_ttl_seconds": 15,
    "quote_reserve_usdt": 25,
    "sync_on_start": true,
    "adopt_broker_inventory": true,
    "use_inventory_buffer": true,
    "reconcile_crypto_balances": true,
    "bot_only_pnl": true
  },
  "paths": {
    "state_path": "state/mexc_state.json",
    "trades_path": "state/mexc_trades.jsonl",
    "rejects_path": "state/mexc_rejects.jsonl",
    "manual_adjustments_path": "state/manual_adjustments.jsonl",
    "manual_positions_file": "state/manual_positions.json",
    "capital_flows_file": "state/capital_flows.json"
  }
}
